generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  firstName     String?
  lastName      String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  
  // Social & Profile Fields
  bio           String?
  website       String?
  linkedin      String?
  github        String?
  
  // Custom Typer Fields
  averageWpm    Float     @default(0)
  topWpm        Float     @default(0)
  totalCompleted Int      @default(0)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastDailyDate DateTime?
  
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  attempts      Attempt[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Challenge {
  id          String   @id @default(cuid())
  serialNo    Int      @unique
  title       String
  difficulty  String   // EASY, MEDIUM, HARD, SUPER_HARD
  content     String   // The text to type
  isDaily     Boolean  @default(false)
  dailyDate   DateTime? @unique // midnight UTC date

  createdAt   DateTime @default(now())
  attempts    Attempt[]
}

model Attempt {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  
  wpm         Float
  accuracy    Float
  timeSeconds Float
  completedAt DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])
}
